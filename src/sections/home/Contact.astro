---
import PhoneIcon from "../../icons/PhoneIcon.astro";
import MailIcon from "../../icons/MailIcon.astro";
import TimeIcon from "../../icons/TimeIcon.astro";
import WhatsappIcon from "../../icons/WhatsappIcon.astro";
---

<section id="contacto" class="bg-[#141414] py-20 md:py-28">
    <div class="max-w-7xl mx-auto px-4 md:px-8">
        <div class="text-center mb-12">
            <p
                class="text-[#D4AF37] text-xs! font-semibold tracking-widest uppercase mb-3"
            >
                Contacto
            </p><h2
                class="text-3xl! md:text-4xl! xl:text-5xl! font-bold text-white leading-tight mb-3"
            >
                Solicita tu <span class="text-[#D4AF37]">presupuesto</span>
            </h2><p class="text-[#B8B8B8] text-base">
                Sin compromiso · Respuesta en 24 horas
            </p>
        </div><div class="grid grid-cols-1 lg:grid-cols-5 gap-10 lg:gap-12">
            <div class="lg:col-span-3">
                <form
                    data-readdy-form="true"
                    id="presupuesto-form"
                    class="bg-[#1E1E1E] rounded-2xl p-6 md:p-8 space-y-5"
                >
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                        <div>
                            <label
                                class="block text-[#C5C5C5] text-sm font-medium mb-2"
                                >Nombre *</label
                            ><input
                                required=""
                                placeholder="Tu nombre completo"
                                class="w-full bg-[#141414] border border-[#333] focus:border-[#D4AF37] text-white text-sm px-4 py-3 rounded-lg outline-none transition-colors placeholder-[#555]"
                                type="text"
                                name="nombre"
                            />
                        </div><div>
                            <label
                                class="block text-[#C5C5C5] text-sm font-medium mb-2"
                                >Email *</label
                            ><input
                                required=""
                                placeholder="tu@email.com"
                                class="w-full bg-[#141414] border border-[#333] focus:border-[#D4AF37] text-white text-sm px-4 py-3 rounded-lg outline-none transition-colors placeholder-[#555]"
                                type="email"
                                name="email"
                            />
                        </div>
                    </div><div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                        <div>
                            <label
                                class="block text-[#C5C5C5] text-sm font-medium mb-2"
                                >Teléfono *</label
                            ><input
                                required=""
                                placeholder="6XX XXX XXX"
                                class="w-full bg-[#141414] border border-[#333] focus:border-[#D4AF37] text-white text-sm px-4 py-3 rounded-lg outline-none transition-colors placeholder-[#555]"
                                type="tel"
                                name="telefono"
                            />
                        </div><div>
                            <label
                                class="block text-[#C5C5C5] text-sm font-medium mb-2"
                                >Tipo de suelo</label
                            ><select
                                name="tipo_suelo"
                                class="w-full bg-[#141414] border border-[#333] focus:border-[#D4AF37] text-white text-sm px-4 py-3 rounded-lg outline-none transition-colors cursor-pointer"
                                ><option value="">Selecciona...</option><option
                                    >Mármol</option
                                ><option>Terrazo</option><option
                                    >Hormigón</option
                                ><option>Piedra natural</option><option
                                    >Granito</option
                                ><option>Otro</option></select
                            >
                        </div>
                    </div><div>
                        <label
                            class="block text-[#C5C5C5] text-sm font-medium mb-2"
                            >Servicio</label
                        ><select
                            name="servicio"
                            class="w-full bg-[#141414] border border-[#333] focus:border-[#D4AF37] text-white text-sm px-4 py-3 rounded-lg outline-none transition-colors cursor-pointer"
                            ><option value="">Selecciona un servicio...</option
                            ><option>Micropulido y Acristalado</option><option
                                >Pulido y Acristalado</option
                            ><option>Restauración Integral</option><option
                                >No lo sé, necesito asesoramiento</option
                            ></select
                        >
                    </div><div>
                        <label
                            class="block text-[#C5C5C5] text-sm font-medium mb-2"
                            >Mensaje <span class="text-[#666] text-xs"
                                >(0/500)</span
                            ></label
                        ><textarea
                            name="mensaje"
                            rows="4"
                            maxlength="500"
                            placeholder="Cuéntanos más sobre tu suelo, superficie aproximada, ubicación..."
                            class="w-full bg-[#141414] border border-[#333] focus:border-[#D4AF37] text-white text-sm px-4 py-3 rounded-lg outline-none transition-colors placeholder-[#555] resize-none"
                        ></textarea>
                    </div><div class="flex items-start gap-3">
                        <input
                            required=""
                            id="privacidad"
                            class="mt-1 accent-[#D4AF37] cursor-pointer"
                            type="checkbox"
                            name="privacidad"
                        /><label
                            for="privacidad"
                            class="text-[#888] text-xs leading-relaxed cursor-pointer"
                            >He leído y acepto la <a
                                href="/politica-privacidad"
                                class="text-[#D4AF37] underline hover:text-[#B8960F]"
                                >Política de Privacidad</a
                            > y el <a
                                href="/aviso-legal"
                                class="text-[#D4AF37] underline hover:text-[#B8960F]"
                                >Aviso Legal</a
                            ></label
                        >
                    </div><button
                        type="submit"
                        class="w-full flex items-center justify-center gap-2 bg-linear-to-r from-[#D4AF37] to-[#B8960F] text-white font-bold text-sm py-4 rounded-full hover:scale-[1.02] hover:shadow-xl hover:shadow-[#D4AF37]/30 transition-all duration-200 cursor-pointer whitespace-nowrap disabled:opacity-60"
                        ><i class="ri-send-plane-fill"></i> ENVIAR CONSULTA</button
                    >
                </form>
            </div><div class="lg:col-span-2 flex flex-col gap-6">
                <div
                    class="bg-[#1E1E1E] rounded-2xl p-6 border-l-4 border-[#D4AF37] space-y-5"
                >
                    <div class="flex items-start gap-4">
                        <span
                            class="w-8 h-8 flex items-center justify-center text-[#D4AF37] shrink-0 mt-0.5"
                            ><i class="ri-map-pin-2-fill text-xl"></i></span
                        ><div>
                            <p
                                class="text-[#888] text-xs uppercase tracking-wide mb-1"
                            >
                                Dirección
                            </p><p class="text-white text-sm">
                                Barrio Santa Clara, Sevilla
                            </p><p class="text-[#B0B0B0] text-xs">
                                Atendemos toda la provincia
                            </p>
                        </div>
                    </div><div class="h-px bg-[#D4AF37]/20"></div><div
                        class="flex items-start gap-4"
                    >
                        <span
                            class="w-8 h-8 flex items-center justify-center text-[#D4AF37] shrink-0 mt-0.5"
                            ><i class="ri-phone-fill text-xl"></i></span
                        ><div>
                            <p
                                class="text-[#888] text-xs uppercase tracking-wide mb-1"
                            >
                                Teléfono
                            </p><a
                                href="tel:1111111111"
                                class="text-white font-bold text-lg hover:text-[#D4AF37] transition-colors cursor-pointer"
                                >1111111111</a
                            >
                        </div>
                    </div><div class="h-px bg-[#D4AF37]/20"></div><div
                        class="flex items-start gap-4"
                    >
                        <span
                            class="w-8 h-8 flex items-center justify-center text-[#D4AF37] shrink-0 mt-0.5"
                            ><i class="ri-mail-fill text-xl"></i></span
                        ><div>
                            <p
                                class="text-[#888] text-xs uppercase tracking-wide mb-1"
                            >
                                Email
                            </p><a
                                href="mailto:info@pulimentosruiz.es"
                                class="text-white text-sm hover:text-[#D4AF37] transition-colors cursor-pointer"
                                >info@pulimentosruiz.es</a
                            >
                        </div>
                    </div><div class="h-px bg-[#D4AF37]/20"></div><div
                        class="flex items-start gap-4"
                    >
                        <span
                            class="w-8 h-8 flex items-center justify-center text-[#D4AF37] shrink-0 mt-0.5"
                            ><i class="ri-time-fill text-xl"></i></span
                        ><div>
                            <p
                                class="text-[#888] text-xs uppercase tracking-wide mb-1"
                            >
                                Horario
                            </p><p class="text-white text-sm">
                                Lun – Sáb: 8:00 – 20:00
                            </p>
                        </div>
                    </div>
                </div><a
                    href="https://wa.me/341111111111?text=Hola%2C%20me%20gustar%C3%ADa%20solicitar%20un%20presupuesto%20para%20pulido%20de%20suelos"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="flex items-center justify-center gap-3 bg-[#25D366] text-white font-semibold text-sm py-4 rounded-full hover:scale-105 transition-all duration-200 cursor-pointer whitespace-nowrap"
                    ><span class="w-5 h-5 flex items-center justify-center">
                        <WhatsappIcon fill="white" />
                    </span>Chatea con nosotros por WhatsApp</a
                ><div class="rounded-2xl overflow-hidden h-56">
                    <iframe
                        title="Ubicación Pulimentos Ruiz Sevilla"
                        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d25298.45!2d-5.9845!3d37.3891!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0xd126c1114be6b3b%3A0x40463fd9d4e3a0!2sSevilla!5e0!3m2!1ses!2ses!4v1"
                        width="100%"
                        height="100%"
                        allowfullscreen=""
                        loading="lazy"
                        referrerpolicy="no-referrer-when-downgrade"
                        style="border: 0px; filter: grayscale(30%) contrast(1.1);"
                    ></iframe>
                </div>
            </div>
        </div>
    </div>
</section>
