---
import JobCard from "../../components/JobCard.astro";

const jobs = [
  {
    before:
      "https://readdy.ai/api/search-image?query=worn%20dull%20scratched%20marble%20floor%20before%20restoration%20Seville%20Spain%20dirty%20old%20surface%20damaged%20stone%20neglected%20interior&width=600&height=450&seq=gallery-before-01&orientation=landscape",
    after:
      "https://readdy.ai/api/search-image?query=polished%20shiny%20marble%20floor%20after%20restoration%20Seville%20Spain%20mirror%20effect%20bright%20clean%20elegant%20interior%20professional%20result&width=600&height=450&seq=gallery-after-01&orientation=landscape",
    floor: "Mármol Blanco",
    service: "Pulido y Acristalado",
  },
  {
    before:
      "https://readdy.ai/api/search-image?query=old%20worn%20terrazzo%20floor%20before%20polishing%20Seville%20Spain%20dull%20surface%20stained%20damaged%20community%20building%20hallway&width=600&height=450&seq=gallery-before-02&orientation=landscape",
    after:
      "https://readdy.ai/api/search-image?query=restored%20terrazzo%20floor%20after%20polishing%20Seville%20Spain%20bright%20shiny%20clean%20community%20building%20hallway%20professional%20result&width=600&height=450&seq=gallery-after-02&orientation=landscape",
    floor: "Terrazo Clásico",
    service: "Micropulido y Acristalado",
  },
  {
    before:
      "https://readdy.ai/api/search-image?query=damaged%20concrete%20floor%20before%20restoration%20Seville%20Spain%20industrial%20building%20worn%20surface%20cracks%20stains%20old&width=600&height=450&seq=gallery-before-03&orientation=landscape",
    after:
      "https://readdy.ai/api/search-image?query=polished%20concrete%20floor%20after%20restoration%20Seville%20Spain%20industrial%20building%20shiny%20smooth%20surface%20professional%20result%20modern&width=600&height=450&seq=gallery-after-03&orientation=landscape",
    floor: "Hormigón Pulido",
    service: "Restauración Integral",
  },
  {
    before:
      "https://readdy.ai/api/search-image?query=old%20natural%20stone%20floor%20before%20polishing%20Seville%20Spain%20worn%20surface%20hotel%20lobby%20dull%20scratched%20damaged&width=600&height=450&seq=gallery-before-04&orientation=landscape",
    after:
      "https://readdy.ai/api/search-image?query=polished%20natural%20stone%20floor%20after%20restoration%20Seville%20Spain%20hotel%20lobby%20bright%20shiny%20elegant%20professional%20result%20luxury&width=600&height=450&seq=gallery-after-04&orientation=landscape",
    floor: "Piedra Natural",
    service: "Pulido y Acristalado",
  },
];
---

<section id="trabajos" class="bg-[#1A1A1A] py-20 md:py-28">
  <div class="max-w-7xl mx-auto px-4 md:px-8">
    <div class="text-center mb-12">
      <p
        class="text-[#D4AF37] text-xs! font-semibold tracking-widest uppercase mb-3"
      >
        Galería
      </p><h2
        class="text-3xl md:text-4xl xl:text-5xl! font-bold text-white leading-tight mb-4"
      >
        Nuestros <span class="text-[#D4AF37]">trabajos</span>
      </h2><p class="text-[#B8B8B8] text-base max-w-xl mx-auto">
        Desliza el comparador para ver la transformación real de cada suelo.
        Resultados garantizados en Sevilla.
      </p>
    </div><div
      class="grid grid-cols-1 sm:grid-cols-2 gap-6 transition-all duration-700 opacity-100 translate-y-0"
    >
      {
        jobs.map((job, index) => (
          <JobCard
            before={job.before}
            after={job.after}
            floor={job.floor}
            service={job.service}
          />
        ))
      }
    </div>
  </div>
</section>
