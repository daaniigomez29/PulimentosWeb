---
import ArrowDownIcon from "../../icons/ArrowDownIcon.astro";
import CalculatorIcon from "../../icons/CalculatorIcon.astro";
import HeartIcon from "../../icons/HeartIcon.astro";
import ImgIcon from "../../icons/ImgIcon.astro";
import LocationIcon from "../../icons/LocationIcon.astro";
import StarIcon from "../../icons/StarIcon.astro";

// Hero component for gobe-studio
---

<div
  id="inicio"
  class="relative min-h-screen flex flex-col justify-center overflow-hidden"
>
  <div class="absolute inset-0">
    <img
      alt="Suelo de mármol pulido efecto espejo en Sevilla - Pulimentos Ruiz"
      title="Pulido y acristalado de suelos en Sevilla"
      class="w-full h-full object-cover object-top"
      loading="eager"
      src="https://readdy.ai/api/search-image?query=polished%20marble%20floor%20mirror%20effect%20high%20gloss%20reflection%20professional%20floor%20polishing%20worker%20Seville%20Spain%20luxury%20interior%20elegant%20stone%20surface%20shining%20bright%20light&width=1920&height=1080&seq=hero-bg-01&orientation=landscape"
    /><div
      class="absolute inset-0 bg-linear-to-r from-[#0D0D0D]/95 via-[#0D0D0D]/80 to-[#0D0D0D]/40"
    >
    </div>
  </div><div
    class="relative z-10 max-w-7xl mx-auto px-4 md:px-8 w-full pt-36 pb-16 md:pt-40 md:pb-20"
  >
    <div class="max-w-2xl xl:max-w-3xl">
      <div
        class="inline-flex items-center gap-2 border border-[#D4AF37]/60 bg-[#D4AF37]/10 rounded-full px-4 py-2 mb-6"
      >
        <span class="text-[#D4AF37] text-xs font-medium tracking-wide"
          >Líderes en Sevilla desde 1998</span
        >
      </div><h1
        class="text-3xl md:text-5xl xl:text-6xl! font-bold text-white leading-tight mb-6"
      >
        Expertos en <span class="text-[#D4AF37]">Pulido y Acristalado</span> de Suelos
        en Sevilla
      </h1><p
        class="text-base md:text-lg text-[#C5C5C5] leading-relaxed mb-8 max-w-xl"
      >
        Recuperamos el brillo de tus suelos con micropulido, pulido y
        acristalado. Servicio rápido, limpio y con garantía en Sevilla y
        alrededores.
      </p><div class="flex flex-col sm:flex-row gap-4 mb-12 md:mb-16">
        <button
          class="flex items-center justify-center gap-2 bg-linear-to-r from-[#D4AF37] to-[#B8960F] text-white font-semibold px-8 py-4 rounded-full whitespace-nowrap hover:scale-105 hover:shadow-xl hover:shadow-[#D4AF37]/30 transition-all duration-200 cursor-pointer text-sm md:text-base"
          ><span class="w-5 h-5 flex items-center justify-center">
            <CalculatorIcon />
          </span>Solicita tu presupuesto ahora</button
        ><button
          class="flex items-center justify-center gap-2 border-2 border-[#D4AF37] text-[#D4AF37] font-semibold px-8 py-4 rounded-full whitespace-nowrap hover:bg-[#D4AF37]/10 transition-all duration-200 cursor-pointer text-sm md:text-base"
          ><span class="w-5 h-5 flex items-center justify-center">
            <ImgIcon />
          </span>Ver nuestros trabajos</button
        >
      </div>
      <div
        class="inline-flex flex-col sm:flex-row items-center gap-0 bg-[#1A1A1A]/80 backdrop-blur-sm rounded-2xl overflow-hidden border border-[#D4AF37]/20"
      >
        <div class="flex items-center gap-4 px-8 py-5">
          <span class="w-8 h-8 flex items-center justify-center text-[#D4AF37]">
            <StarIcon />
          </span><div>
            <div class="text-3xl md:text-4xl font-bold text-[#D4AF37]">
              +25
            </div><div class="text-xs md:text-sm text-[#B0B0B0]">
              años de experiencia
            </div>
          </div>
        </div><div class="w-px h-16 bg-[#D4AF37]/30 hidden sm:block"></div><div
          class="w-full h-px bg-[#D4AF37]/30 sm:hidden"
        >
        </div><div class="flex items-center gap-4 px-8 py-5">
          <span class="w-8 h-8 flex items-center justify-center text-[#D4AF37]">
            <HeartIcon />
          </span><div>
            <div class="text-3xl md:text-4xl font-bold text-[#D4AF37]">
              +100
            </div><div class="text-xs md:text-sm text-[#B0B0B0]">
              clientes contentos en Sevilla
            </div>
          </div>
        </div>
      </div>
    </div>
  </div><div
    class="absolute bottom-8 left-1/2 -translate-x-1/2 flex-col items-center gap-2 animate-bounce hidden sm:flex"
  >
    <span class="text-[#D4AF37]/60 text-xs">Descubre más</span><span
      class="w-5 h-5 flex items-center justify-center text-[#D4AF37]/60"
    >
      <ArrowDownIcon />
    </span>
  </div>
</div>
