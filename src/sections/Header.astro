---
import PhoneIcon from "../icons/PhoneIcon.astro";
import MailIcon from "../icons/MailIcon.astro";
import ClockIcon from "../icons/ClockIcon.astro";
import NextArrowIcon from "../icons/NextArrowIcon.astro";
import HambuguerMenuIcon from "../icons/HambuguerMenuIcon.astro";
import CloseMenuIcon from "../icons/CloseMenuIcon.astro";

const navItems = [
  { label: "Inicio", href: "#inicio" },
  { label: "Sobre Nosotros", href: "#sobre-nosotros" },
  { label: "Servicios", href: "#servicios" },
  { label: "Trabajos", href: "#trabajos" },
  { label: "Opiniones", href: "#opiniones" },
  { label: "Contacto", href: "#contacto" },
];
---

<header class="fixed top-0 left-0 right-0 z-50 pb-4">
  <!-- TOP BAR -->
  <div class="bg-[#151515] py-2 px-4 md:px-8">
    <div
      class="max-w-7xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-1 sm:gap-0"
    >
      <div class="flex items-center gap-4 md:gap-6">
        <a
          class="flex items-center gap-2 text-white hover:text-[#D4AF37] transition-colors cursor-pointer whitespace-nowrap"
        >
          <PhoneIcon />
          <p class="text-sm! md:text-md!">691 88 63 70</p>
        </a>
        <span class="text-[#D4AF37] opacity-50 hidden sm:block">|</span>
        <a
          class="flex items-center gap-2 text-white hover:text-[#D4AF37] transition-colors cursor-pointer whitespace-nowrap"
        >
          <MailIcon />
          <p class="text-sm! md:text-md!">pulimentosruiz@gmail.com</p>
        </a>
      </div>
      <div class="flex items-center gap-2 text-[#B0B0B0]">
        <ClockIcon />
        <p class="text-sm! md:text-md!">Lun-Vie 8:30 - 18:00</p>
      </div>
    </div>
  </div>

  <!-- NAVBAR -->
  <nav id="main-nav" class="bg-[#1A1A1A]/95 transition-all duration-300">
    <div
      class="max-w-7xl mx-auto px-4 md:px-8 flex items-center justify-between h-16 md:h-20"
    >
      <!-- Logo -->
      <a href="#inicio" class="flex items-center gap-3 cursor-pointer nav-link">
        <img
          alt="Pulimentos Ruiz logo pulido acristalado suelos Sevilla"
          class="h-10 md:h-12 w-auto rounded-md object-contain"
          src="assets/logos/logo.jpeg"
        />
        <span
          class="text-white font-semibold text-base md:text-lg hidden sm:block"
        >
          Pulimentos <span class="text-[#D4AF37]">Ruiz</span>
        </span>
      </a>

      <!-- Desktop menu -->
      <ul class="hidden xl:flex items-center gap-6 xl:gap-8">
        {
          navItems.map((item) => (
            <li>
              <a
                href={item.href}
                data-section={item.href.replace("#", "")}
                class="nav-link text-sm font-medium transition-all duration-200 cursor-pointer whitespace-nowrap pb-1 border-b-2 text-[#E0E0E0] border-transparent hover:text-[#D4AF37] hover:border-[#D4AF37]"
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>

      <!-- CTA + hamburger -->
      <div class="flex items-center gap-3">
        <a
          href="#contacto"
          class="nav-link hidden xl:flex items-center gap-2 bg-linear-to-r from-[#D4AF37] to-[#B8960F] text-white text-xs xl:text-sm font-semibold px-4 xl:px-6 py-2.5 rounded-full whitespace-nowrap hover:scale-105 hover:shadow-lg hover:shadow-[#D4AF37]/30 transition-all duration-200 cursor-pointer"
        >
          Solicita presupuesto gratis
          <span class="w-4 h-4 flex items-center justify-center">
            <NextArrowIcon />
          </span>
        </a>
        <button
          id="menu-toggle-btn"
          class="xl:hidden w-10 h-10 flex items-center justify-center text-[#D4AF37] cursor-pointer"
          aria-label="Abrir menú"
          aria-expanded="false"
        >
          <!-- Hamburger icon -->
          <HambuguerMenuIcon />
          <!-- Close icon (hidden by default) -->
          <CloseMenuIcon />
        </button>
      </div>
    </div>

    <!-- Mobile menu -->
    <div
      id="mobile-menu"
      class="xl:hidden hidden bg-[#1A1A1A]/98 backdrop-blur-md border-t border-[#D4AF37]/20"
    >
      <ul class="flex flex-col py-4">
        {
          navItems.map((item) => (
            <li>
              <a
                href={item.href}
                data-section={item.href.replace("#", "")}
                class="nav-link mobile-nav-link w-full text-left px-6 py-3 text-[#E0E0E0] hover:text-[#D4AF37] hover:bg-[#D4AF37]/10 text-sm font-medium transition-colors cursor-pointer block"
              >
                {item.label}
              </a>
            </li>
          ))
        }
        <li class="px-6 pt-3 pb-2">
          <a
            href="#contacto"
            class="nav-link mobile-nav-link block w-full text-center bg-linear-to-r from-[#D4AF37] to-[#B8960F] text-white text-sm font-semibold py-3 rounded-full cursor-pointer"
          >
            Solicita presupuesto gratis
          </a>
        </li>
      </ul>
    </div>
  </nav>
</header>

<script>
  const nav = document.getElementById("main-nav")!;
  const toggleBtn = document.getElementById("menu-toggle-btn")!;
  const mobileMenu = document.getElementById("mobile-menu")!;
  const iconOpen = document.getElementById("icon-open")!;
  const iconClose = document.getElementById("icon-close")!;
  const navLinks = document.querySelectorAll<HTMLAnchorElement>(".nav-link");
  const desktopLinks =
    document.querySelectorAll<HTMLAnchorElement>("[data-section]");

  // --- Scroll: background + active section ---
  function onScroll() {
    // Active section highlight
    const sections = [
      "inicio",
      "sobre-nosotros",
      "servicios",
      "trabajos",
      "opiniones",
      "contacto",
    ];
    let current = "inicio";

    for (const id of sections) {
      const el = document.getElementById(id);
      if (el && window.scrollY >= el.offsetTop - 120) {
        current = id;
      }
    }

    desktopLinks.forEach((link) => {
      const isActive = link.dataset.section === current;
      link.classList.toggle("text-[#D4AF37]", isActive);
      link.classList.toggle("border-[#D4AF37]", isActive);
      link.classList.toggle("text-[#E0E0E0]", !isActive);
      link.classList.toggle("border-transparent", !isActive);
    });
  }

  window.addEventListener("scroll", onScroll, { passive: true });
  onScroll(); // Run on load

  // --- Hamburger toggle ---
  toggleBtn.addEventListener("click", () => {
    const isOpen = !mobileMenu.classList.contains("hidden");
    mobileMenu.classList.toggle("hidden", isOpen);
    iconOpen.classList.toggle("hidden", !isOpen);
    iconClose.classList.toggle("hidden", isOpen);
    toggleBtn.setAttribute("aria-expanded", String(!isOpen));
  });

  // --- Smooth scroll + close mobile menu on link click ---
  navLinks.forEach((link) => {
    link.addEventListener("click", (e) => {
      const href = link.getAttribute("href");
      if (!href?.startsWith("#")) return;

      e.preventDefault();
      const target = document.getElementById(href.replace("#", ""));
      if (target) target.scrollIntoView({ behavior: "smooth" });

      // Close mobile menu if open
      mobileMenu.classList.add("hidden");
      iconOpen.classList.remove("hidden");
      iconClose.classList.add("hidden");
      toggleBtn.setAttribute("aria-expanded", "false");
    });
  });
</script>
