---
import WhatsappIcon from "../icons/WhatsappIcon.astro";
---

<footer
    class="bg-[#020617] text-slate-400 py-16 px-6 lg:px-20 border-t border-slate-800/50"
>
    <div
        class="max-w-7xl mx-auto flex flex-col lg:flex-row justify-between gap-12 lg:gap-8"
    >
        <div class="lg:w-1/3 flex flex-col gap-5">
            <p class="text-white text-xl md:text-2xl font-bold">Gobe Studio</p>
            <p
                class="text-slate-400 leading-relaxed pr-2 md:pr-8 text-sm md:text-base"
            >
                Experto en desarrollo web de alto impacto en Sevilla. Llevo la
                presencia digital de los negocios locales al siguiente nivel.
            </p>
            <div class="flex gap-5">
                <a
                    href="https://wa.me/674778285"
                    target="_blank"
                    aria-label="Enviar mensaje por WhatsApp"
                    rel="noopener noreferrer"
                >
                    <WhatsappIcon />
                </a>
            </div>
        </div>

        <div
            class="flex flex-col sm:flex-row gap-12 sm:gap-16 xl:gap-32 w-full lg:w-auto lg:pr-10"
        >
            <div class="flex flex-col gap-6">
                <h3
                    class="text-white text-xs md:text-sm! font-bold tracking-widest uppercase"
                >
                    Empresa
                </h3>
                <ul class="flex flex-col gap-5 text-sm md:text-base">
                    <li>
                        <a
                            href="/servicios"
                            class="hover:text-white transition-colors"
                            >Servicios</a
                        >
                    </li>
                    <li>
                        <a
                            href="#contacto"
                            class="hover:text-white transition-colors"
                            >Formulario de contacto</a
                        >
                    </li>
                    <li>
                        <a
                            href="#soluciones"
                            class="hover:text-white transition-colors"
                            >Soluciones</a
                        >
                    </li>
                    <li>
                        <a
                            href="#nuestros-trabajos"
                            class="hover:text-white transition-colors"
                            >Trabajos</a
                        >
                    </li>
                </ul>
            </div>

            <div class="flex flex-col gap-6">
                <h3
                    class="text-white text-xs md:text-sm! font-bold tracking-widest uppercase"
                >
                    Contacta conmigo
                </h3>
                <ul class="flex flex-col gap-5 text-sm md:text-base">
                    <li>
                        <a
                            href="tel:+34674778285"
                            class="hover:text-white transition-colors"
                            >+34 674 77 82 85</a
                        >
                    </li>
                    <li>
                        <a
                            href="mailto:gobestudio29@gmail.com"
                            class="hover:text-white transition-colors"
                            >gobestudio29@gmail.com</a
                        >
                    </li>
                    <li>
                        <a
                            href="https://wa.me/674778285"
                            target="_blank"
                            rel="noopener noreferrer"
                            aria-label="Enviar mensaje por WhatsApp"
                            class="hover:text-green-500 transition duration-200"
                            >WhatsApp</a
                        >
                    </li>
                </ul>
            </div>

            <div class="flex flex-col gap-6">
                <h3
                    class="text-white text-xs md:text-sm! font-bold tracking-widest uppercase"
                >
                    Legal
                </h3>
                <ul class="flex flex-col gap-5 text-sm md:text-base">
                    <li>
                        <a
                            href="/politica-privacidad"
                            class="hover:text-white transition-colors"
                            >Política de privacidad</a
                        >
                    </li>
                    <li>
                        <a
                            href="/aviso-legal"
                            class="hover:text-white transition-colors"
                            >Aviso legal</a
                        >
                    </li>
                    <li>
                        <a
                            href="/accesibilidad"
                            class="hover:text-white transition-colors"
                            >Accesibilidad</a
                        >
                    </li>
                </ul>
            </div>
        </div>
    </div>

    <div
        class="max-w-7xl mx-auto mt-20 pt-8 border-slate-800/80 text-sm text-slate-500"
    >
        <p>&copy; 2026 Gobe Studio. Todos los derechos reservados.</p>
    </div>
</footer>
