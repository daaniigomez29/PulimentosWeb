---
import ClockIcon from "../icons/ClockIcon.astro";
import FacebookIcon from "../icons/FacebookIcon.astro";
import GoogleIcon from "../icons/GoogleIcon.astro";
import InstagramIcon from "../icons/InstagramIcon.astro";
import LocationIcon from "../icons/LocationIcon.astro";
import MailIcon from "../icons/MailIcon.astro";
import PhoneIcon from "../icons/PhoneIcon.astro";
import WhatsappIcon from "../icons/WhatsappIcon.astro";
---

<footer id="footer" class="bg-[#0F0F0F] pt-16 pb-6">
    <div class="max-w-7xl mx-auto px-4 md:px-8">
        <div
            class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10 mb-12"
        >
            <div>
                <div class="flex items-center gap-3 mb-4">
                    <img
                        alt="Pulimentos Ruiz"
                        class="h-10 w-auto rounded-md"
                        src="https://static.readdy.ai/image/4b9dbb29d2c37c7158e753421965795f/a6c67dd16af90476330940747724314e.jpeg"
                    /><span class="text-white font-semibold text-base"
                        >Pulimentos <span class="text-[#D4AF37]">Ruiz</span
                        ></span
                    >
                </div><p
                    class="text-[#888] text-sm italic leading-relaxed mb-5"
                >
                    "Devolviendo el brillo a tus espacios desde 1998"
                </p><div class="flex gap-3">
                    <a
                        href="#"
                        rel="nofollow noopener noreferrer"
                        class="w-9 h-9 flex items-center justify-center bg-[#1E1E1E] rounded-full text-[#888] hover:text-[#D4AF37] hover:bg-[#D4AF37]/10 transition-all duration-200 cursor-pointer"
                    >
                        <FacebookIcon stroke="#888" height="15" width="15" /></a
                    ><a
                        href="#"
                        rel="nofollow noopener noreferrer"
                        class="w-9 h-9 flex items-center justify-center bg-[#1E1E1E] rounded-full text-[#888] hover:text-[#D4AF37] hover:bg-[#D4AF37]/10 transition-all duration-200 cursor-pointer"
                    >
                        <InstagramIcon
                            stroke="#888"
                            height="15"
                            width="15"
                        /></a
                    ><a
                        href="#"
                        rel="nofollow noopener noreferrer"
                        class="w-9 h-9 flex items-center justify-center bg-[#1E1E1E] rounded-full text-[#888] hover:text-[#D4AF37] hover:bg-[#D4AF37]/10 transition-all duration-200 cursor-pointer"
                        ><WhatsappIcon fill="#888" height="15" width="15" /></a
                    ><a
                        href="#"
                        rel="nofollow noopener noreferrer"
                        class="w-9 h-9 flex items-center justify-center bg-[#1E1E1E] rounded-full text-[#888] hover:text-[#D4AF37] hover:bg-[#D4AF37]/10 transition-all duration-200 cursor-pointer"
                    >
                        <GoogleIcon />
                    </a>
                </div>
            </div><div>
                <h4
                    class="text-[#D4AF37] font-semibold text-sm uppercase tracking-widest mb-5"
                >
                    <a href="#inicio">Navegación</a>
                </h4><ul class="space-y-2">
                    <li>
                        <button
                            class="text-[#888] hover:text-[#D4AF37] text-sm cursor-pointer hover:translate-x-1 inline-block transition-transform"
                            >Inicio</button
                        >
                    </li><li>
                        <button
                            class="text-[#888] hover:text-[#D4AF37] text-sm cursor-pointer hover:translate-x-1 inline-block transition-transform"
                            >Sobre Nosotros</button
                        >
                    </li><li>
                        <button
                            class="text-[#888] hover:text-[#D4AF37] text-sm cursor-pointer hover:translate-x-1 inline-block transition-transform"
                            >Servicios</button
                        >
                    </li><li>
                        <button
                            class="text-[#888] hover:text-[#D4AF37] text-sm cursor-pointer hover:translate-x-1 inline-block transition-transform"
                            >Trabajos</button
                        >
                    </li><li>
                        <button
                            class="text-[#888] hover:text-[#D4AF37] text-sm cursor-pointer hover:translate-x-1 inline-block transition-transform"
                            >Opiniones</button
                        >
                    </li><li>
                        <button
                            class="text-[#888] hover:text-[#D4AF37] text-sm cursor-pointer hover:translate-x-1 inline-block transition-transform"
                            >Contacto</button
                        >
                    </li>
                </ul>
            </div><div>
                <h4
                    class="text-[#D4AF37] font-semibold text-sm uppercase tracking-widest mb-5"
                >
                    <a href="#servicios">Servicios</a>
                </h4><ul class="space-y-2">
                    <li>
                        <button
                            class="text-[#888] hover:text-[#D4AF37] text-sm transition-colors cursor-pointer text-left"
                            >Micropulido y Acristalado</button
                        >
                    </li><li>
                        <button
                            class="text-[#888] hover:text-[#D4AF37] text-sm transition-colors cursor-pointer text-left"
                            >Pulido y Acristalado</button
                        >
                    </li><li>
                        <button
                            class="text-[#888] hover:text-[#D4AF37] text-sm transition-colors cursor-pointer text-left"
                            >Restauración Integral</button
                        >
                    </li><li>
                        <button
                            class="text-[#888] hover:text-[#D4AF37] text-sm transition-colors cursor-pointer text-left"
                            >Pulido de Mármol</button
                        >
                    </li><li>
                        <button
                            class="text-[#888] hover:text-[#D4AF37] text-sm transition-colors cursor-pointer text-left"
                            >Pulido de Terrazo</button
                        >
                    </li><li>
                        <button
                            class="text-[#888] hover:text-[#D4AF37] text-sm transition-colors cursor-pointer text-left"
                            >Pulido de Hormigón</button
                        >
                    </li>
                </ul>
            </div><div>
                <h4
                    class="text-[#D4AF37] font-semibold text-sm uppercase tracking-widest mb-5"
                >
                    <a href="#contacto">Contacto</a>
                </h4><ul class="space-y-3">
                    <li class="flex items-start gap-2 text-[#888] text-sm">
                        <span
                            class="w-4 h-4 flex items-center justify-center text-[#D4AF37] mt-0.5 shrink-0"
                        >
                            <LocationIcon />
                        </span>Barrio Santa Clara, Sevilla
                    </li><li>
                        <a
                            href="tel:1111111111"
                            class="flex items-center gap-2 text-[#888] hover:text-[#D4AF37] text-sm transition-colors cursor-pointer"
                            ><span
                                class="w-4 h-4 flex items-center justify-center text-[#D4AF37] shrink-0"
                            >
                                <PhoneIcon />
                            </span>1111111111</a
                        >
                    </li><li>
                        <a
                            href="mailto:info@pulimentosruiz.es"
                            class="flex items-center gap-2 text-[#888] hover:text-[#D4AF37] text-sm transition-colors cursor-pointer"
                            ><span
                                class="w-4 h-4 flex items-center justify-center text-[#D4AF37] shrink-0"
                            >
                                <MailIcon />
                            </span>info@pulimentosruiz.es</a
                        >
                    </li><li
                        class="flex items-center gap-2 text-[#888] text-sm"
                    >
                        <span
                            class="w-4 h-4 flex items-center justify-center text-[#D4AF37] shrink-0"
                        >
                            <ClockIcon />
                        </span>Lun–Sáb 8:00–20:00
                    </li>
                </ul>
            </div>
        </div><div class="h-px bg-[#D4AF37]/20 mb-6"></div><div
            class="flex flex-col sm:flex-row items-center justify-between gap-3"
        >
            <p class="text-[#555] text-xs! text-center sm:text-left">
                © 2026 Pulimentos Ruiz · Todos los derechos reservados · Sevilla
            </p><div class="flex items-center gap-4">
                <a
                    href="/aviso-legal"
                    class="text-[#555] hover:text-[#D4AF37] text-xs! transition-colors cursor-pointer"
                    >Aviso Legal</a
                ><span class="text-[#333]">|</span><a
                    href="/politica-privacidad"
                    class="text-[#555] hover:text-[#D4AF37] text-xs! transition-colors cursor-pointer"
                    >Política de Privacidad</a
                >
            </div>
        </div><p class="text-center text-[#333] text-xs! mt-4">
            Diseñado para resultados · Optimizado para Sevilla
        </p>
    </div>
</footer>
