---
export interface Props {
    text: string;
    company: string;
    profession: string;
    initial?: string;
}

const { text, company, profession, initial } = Astro.props;
const displayInitial = initial || company.charAt(0).toUpperCase();
---

<div class="w-full shrink-0 flex flex-col items-center justify-center">
    <blockquote
        class="text-lg sm:text-xl md:text-2xl italic text-slate-300 font-light text-center leading-relaxed max-w-4xl mb-10"
    >
        "{text}"
    </blockquote>

    <div class="flex flex-col sm:flex-row items-center gap-4">
        <div
            class="w-10 h-10 sm:w-12 sm:h-12 bg-black rounded-full flex items-center justify-center border border-[#15b1ff]/30 shrink-0 shadow-[0_0_15px_rgba(21,177,255,0.15)]"
        >
            <img
                src={`/assets/customers/${displayInitial}.webp`}
                alt={company}
                class="object-cover"
            />
        </div>
        <div class="text-center sm:text-left">
            <h3
                class="text-[14px]! text-slate-200 font-bold text-sm tracking-widest uppercase mb-1"
            >
                {company}
            </h3>
            <p class="text-[#15b1ff] text-xs font-semibold">
                {profession}
            </p>
        </div>
    </div>
</div>
