---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<div class="bg-[#0b1221] border border-slate-800/50 rounded-2xl flex flex-col items-center justify-center p-6 sm:aspect-[4/3] hover:bg-[#10182b] hover:border-slate-700/50 transition-all duration-300 group cursor-default shadow-lg shadow-black/20">
  <div class="text-[#15b1ff] mb-4 transform transition-transform group-hover:scale-110 duration-300">
    <slot name="icon" />
  </div>
  <h3 class="text-sm font-semibold text-slate-200 tracking-wide">{title}</h3>
</div>
