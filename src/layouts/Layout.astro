---
import Header from "../sections/Header.astro";
import Footer from "../sections/Footer.astro";
import WhatsappIcon from "../icons/WhatsappIcon.astro";

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="es" class="font-['Poppins'] scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" href="/favicon.ico" />
		<!-- Favicon básico -->
		<link
			rel="icon"
			type="image/png"
			sizes="16x16"
			href="/assets/logos/icon-16.png"
		/>
		<link
			rel="icon"
			type="image/png"
			sizes="32x32"
			href="/assets/logos/icon-32.png"
		/>

		<!-- Apple -->
		<link
			rel="apple-touch-icon"
			sizes="180x180"
			href="/assets/logos/apple-touch-icon.png"
		/>

		<!-- Android / PWA -->
		<link
			rel="icon"
			type="image/png"
			sizes="192x192"
			href="/assets/logos/icon-192.png"
		/>
		<link
			rel="icon"
			type="image/png"
			sizes="512x512"
			href="/assets/logos/icon-512.png"
		/>

		<!-- Manifest -->
		<link rel="manifest" href="/site.webmanifest" />

		<title>{title}</title>

		<meta name="description" content={description} />
		<meta
			name="keywords"
			content="pulimentos Sevilla, pulido de suelos Sevilla, acristalado de suelos Sevilla, pulimentos de mármol Sevilla, pulimentos de terrazo Sevilla, pulimentos de granito Sevilla, pulimentos de hormigón Sevilla, pulimentos de barro Sevilla, pulimentos de piedra natural Sevilla, pulimentos de terrazo Sevilla, pulimentos de terrazo Sevilla"
		/>
		<meta name="author" content="daaniigomez29" />
		<meta name="robots" content="index, follow" />

		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta
			property="og:image"
			content="https://www..es/assets/logos/gobe_logo.png"
		/>

		<link rel="canonical" href="https://www..es/" />

		<meta property="og:url" content="https://www..es/" />

		<meta property="og:type" content="website" />

		<script type="application/ld+json">
			{
				"@context": "https://schema.org",
				"@graph": [
					{
						"@type": "WebSite",
						"@id": "https://www..es/#website",
						"name": "Pulimentos Ruiz",
						"url": "https://www..es"
					},
					{
						"@type": "WebPage",
						"@id": "https://www..es/#webpage",
						"name": "Desarrollador web para negocios en Sevilla | Gobe Studio",
						"url": "https://www..es",
						"isPartOf": {
							"@id": "https://www..es/#website"
						}
					},
					{
						"@type": "LocalBusiness",
						"@id": "https://www..es/#business",
						"name": "Pulimentos",
						"telephone": "+34 674 77 82 85",
						"url": "https://www..es",
						"logo": "https://www..es/assets/logos/gobe_logo.png",
						"description": "Pulido y acristalado de suelos en Sevilla. Expertos en pulido de mármol, terrazo, granito, hormigón, barro y piedra natural.",
						"areaServed": {
							"@type": "City",
							"name": "Sevilla"
						}
					}
				]
			}
		</script>

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body>
		<!--Whatsapp button-->
		<a
			href="https://wa.me/111111111"
			target="_blank"
			class="group hover:scale-110 transition duration-300 rounded-full fixed bottom-0 inset-e-0 m-4 whatsapp-icon flex justify-center items-center"
			style="z-index: 1001;"
			aria-label="Enviar mensaje por WhatsApp"
			rel="noopener noreferrer"
		>
			<WhatsappIcon
				class=""
				fill="#FFFF"
				width="30"
				height="30"
				aria-hidden="true"
			/>
		</a>

		<div class="min-h-full">
			<Header />
			<slot />
			<Footer />
		</div>
	</body>
</html>

<style is:global>
	@import "../styles/global.css";

	/* Encabezados base (móvil) */
	h1 {
		font-size: 1.8rem;
	} /* 28.8px */
	h2 {
		font-size: 1.5rem;
	} /* 24px */
	p {
		font-size: 1rem;
	} /* 14px */
	.font-size-small {
		font-size: 1rem;
	} /* 14px */
	li {
		font-size: 1rem;
	} /* 14px */

	/* Tablet / PC */
	@media (min-width: 768px) {
		h1 {
			font-size: 2.5rem;
		} /* 40px */
		h2 {
			font-size: 2rem;
		} /* 32px */
		p {
			font-size: 1rem;
		} /* 16px */
		.font-size-small {
			font-size: 1rem;
		} /* 16px */
		li {
			font-size: 1rem;
		} /* 14px */
	}

	/* Pantallas grandes */
	@media (min-width: 1440px) {
		h1 {
			font-size: 2.5rem;
		} /* 40px */
		h2 {
			font-size: 2.25rem;
		} /* 36px */
		h3 {
			font-size: 1rem;
		} /* 24px */
		p {
			font-size: 1rem;
		} /* 18px */
		.font-size-small {
			font-size: 1rem;
		} /* 16px */
		li {
			font-size: 1rem;
		} /* 16px */
	}

	h6 {
		font-weight: bold;
	}

	.whatsapp-icon {
		height: 70px;
		width: 70px;
		background: #25d366;
		color: white;
		box-shadow: 3px 3px 3px black;
		min-width: 50px;
		min-height: 50px;
		max-width: 80px;
		max-height: 80px;
	}

	.background-fade {
		background: linear-gradient(45deg, #f9fafc 0%, #eaeff6 100%);
	}
</style>
